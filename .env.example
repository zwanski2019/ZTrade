# ---------------------------------------------------------------------------
# ZTrade configuration. Copy to .env and fill in. NEVER commit .env.
# ---------------------------------------------------------------------------

PORT=8788
HOST=127.0.0.1
CORS_ORIGIN=http://localhost:5173

# --- Safety switches -------------------------------------------------------
# TESTNET is the default and is what you want until the strategy is proven.
# MAINNET additionally requires ZTRADE_ALLOW_MAINNET=true — two switches so a
# single typo cannot point the bot at real money.
ZTRADE_NETWORK=TESTNET
ZTRADE_ALLOW_MAINNET=false

# With this false the engine runs, evaluates strategies and SIMULATES fills
# (paper mode) but never sends an order. Flip it only when you mean it.
ZTRADE_TRADING_ENABLED=false

# --- Security --------------------------------------------------------------
# Bearer token required by the API and the WebSocket. Leave blank and one is
# generated on first run and printed to the console — set it here to pin it.
ZTRADE_API_TOKEN=

# Only turn auth off for local development you fully control. The server
# REFUSES to start with auth off while live-trading on mainnet.
ZTRADE_AUTH_ENABLED=true

# Passphrase used to encrypt stored secrets (the Telegram token) at rest.
# Defaults to the API token if unset. Changing it makes existing stored
# secrets unreadable — they simply need re-entering.
ZTRADE_SECRET_KEY=

# Requests per minute, per IP.
ZTRADE_RATE_LIMIT=240

# --- Bybit credentials -----------------------------------------------------
# Testnet keys: https://testnet.bybit.com/app/user/api-management
# Grant ONLY "Trade" + "Read". Never enable withdrawal permission on a bot key.
BYBIT_API_KEY=
BYBIT_API_SECRET=

# --- Telegram alerts (optional) --------------------------------------------
# Set here and they never touch the database. Set them in the UI instead and
# they are stored encrypted.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Storage ---------------------------------------------------------------
DATABASE_PATH=./data/ztrade.db
